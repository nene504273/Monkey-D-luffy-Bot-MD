let handler = async (m, { command, conn, args, usedPrefix }) => {
  // Aseguramos que el usuario exista en la base de datos
  let user = global.db.data.users[m.sender]
  if (!user) return

  // Función interna para subir de nivel y notificar
  const revisarNivel = (u) => {
    if (u.pet.experiencia >= 100) {
      u.pet.experiencia = 0
      u.pet.nivel += 1
      conn.reply(m.chat, `*¡Felicidades!* 🆙\nTu mascota *${u.pet.nombre}* ha subido al nivel *${u.pet.nivel}*`, m)
    }
  }

  switch (command) {
    case 'crearpet':
      if (user.pet) return m.reply('*⚠️ Ya tienes una mascota creada.*')
      let nombrePet = args.join(' ') || 'NagiPet'
      user.pet = {
        nombre: nombrePet,
        hambre: 50,
        energia: 50,
        diversion: 50,
        nivel: 1,
        experiencia: 0,
      }
      m.reply(`*✨ Mascota creada con éxito*\n\n*Nombre:* ${user.pet.nombre}\n*Nivel:* 1\n\n¡Cuídala bien! Usa *${usedPrefix}perfilpet* para ver su estado.`)
      break

    case 'perfilpet':
      if (!user.pet) return m.reply(`*❌ No tienes mascota.*\nUsa ${usedPrefix}crearpet para iniciar.`)
      let { nombre, nivel, hambre, energia, diversion, experiencia } = user.pet
      let info = `*🐾 Perfil de tu Mascota*\n\n` +
                 `*• Nombre:* ${nombre}\n` +
                 `*• Nivel:* ${nivel}\n` +
                 `*┈┈┈┈┈┈┈┈┈┈┈┈┈*\n` +
                 `*• Hambre:* [${hambre}/100]\n` +
                 `*• Energía:* [${energia}/100]\n` +
                 `*• Diversión:* [${diversion}/100]\n` +
                 `*• XP:* [${experiencia}/100]`
      m.reply(info)
      break

    case 'alimentarpet':
      if (!user.pet) return m.reply(`*❌ No tienes mascota.*`)
      if (user.pet.hambre >= 100) return m.reply('*🍎 Tu mascota ya está llena.*')
      
      user.pet.hambre = Math.min(100, user.pet.hambre + 30)
      user.pet.experiencia += 20
      m.reply(`*🍲 Alimentaste a ${user.pet.nombre}*\n+30 Hambre | +20 XP`)
      revisarNivel(user)
      break

    case 'jugarpet':
      if (!user.pet) return m.reply(`*❌ No tienes mascota.*`)
      if (user.pet.diversion >= 100) return m.reply('*🧸 Tu mascota ya está muy feliz.*')
      if (user.pet.energia < 10) return m.reply('*💤 Está muy cansada para jugar.*')
      
      user.pet.diversion = Math.min(100, user.pet.diversion + 30)
      user.pet.energia -= 10
      user.pet.experiencia += 20
      m.reply(`*🎮 Jugaste con ${user.pet.nombre}*\n+30 Diversión | -10 Energía | +20 XP`)
      revisarNivel(user)
      break

    case 'dormirpet':
      if (!user.pet) return m.reply(`*❌ No tienes mascota.*`)
      if (user.pet.energia >= 100) return m.reply('*🛌 Tu mascota ya está descansada.*')
      
      user.pet.energia = Math.min(100, user.pet.energia + 40)
      user.pet.hambre -= 5
      user.pet.experiencia += 10
      m.reply(`*💤 ${user.pet.nombre} tomó una siesta*\n+40 Energía | -5 Hambre | +10 XP`)
      revisarNivel(user)
      break
  }
}

handler.help = ['crearpet', 'perfilpet', 'alimentarpet', 'jugarpet', 'dormirpet']
handler.tags = ['pet']
handler.command = /^(crearpet|perfilpet|alimentarpet|jugarpet|dormirpet)$/i

export default handler